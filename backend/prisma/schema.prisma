generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Listing {
  id       Int    @id @default(autoincrement())
  title    String
  price    Int
  city     String
  category String
  userId   Int
  user User @relation(fields: [userId], references: [id])
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  username String
  password String
  listings Listing[]
}