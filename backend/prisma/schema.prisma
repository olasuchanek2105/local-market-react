generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Listing {
  id       Int    @id @default(autoincrement())
  title    String
  price    Int
  city     String
  category String
}

model User {
id Int @id @default(autoincrement())
email String @unique
username String
password String
}